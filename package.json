{
    "name": "hdl-studio",
    "displayName": "HDL Studio",
    "description": "HDL Studio is a vscode extension for digitaljs, a digital circuit simulator.",
    "version": "0.0.1",
    "license": "See LICENSE",
    "publisher": "TwinT",
    "repository": {
        "type": "git",
        "url": "https://github.com/TwinT/hdl-studio.git"
    },
    "engines": {
        "vscode": "^1.62.0"
    },
    "icon": "imgs/hdl-studio.png",
    "categories": [
        "Debuggers",
        "Education",
        "Programming Languages",
        "Visualization",
        "Other"
    ],
    "keywords": [
        "verilog",
        "simulation"
    ],
    "activationEvents": [
        "onCustomEditor:hdl-studio.circuitView",
        "onCommand:hdl-studio.openView",
        "onCommand:hdl-studio.openViewJSON",
        "onCommand:hdl-studio.addToViewSource",
        "onCommand:hdl-studio.newViewSource",
        "onCommand:hdl-studio.newJSON",
        "onCommand:hdl-studio.addFiles",
        "onCommand:hdl-studio.exportImage",
        "onCommand:hdl-studio.removeSource",
        "onView:hdl-studio-proj-files",
        "onView:hdl-studio-proj-synth",
        "onView:hdl-studio-proj-status"
    ],
    "main": "./dist/local-extension.js",
    "browser": "./dist/web-extension.js",
    "contributes": {
        "commands": [
            {
                "command": "hdl-studio.openView",
                "title": "Open HDL Studio",
                "icon": "imgs/hdl-studio.svg",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.showPanel",
                "title": "Show HDL Studio Panel",
                "icon": "imgs/hdl-studio.svg",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.openViewJSON",
                "title": "Open as circuit in HDL Studio",
                "icon": "imgs/hdl-studio.svg",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.addToViewSource",
                "title": "Add to HDL Studio",
                "icon": "imgs/hdl-studio.svg",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.newViewSource",
                "title": "Create circuit in HDL Studio",
                "icon": "imgs/hdl-studio.svg",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.revealCircuit",
                "title": "Show active circuit",
                "icon": "$(output-view-icon)",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.pause",
                "title": "Pause",
                "icon": "$(debug-pause)",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.start",
                "title": "Start",
                "icon": "$(debug-start)",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.newJSON",
                "title": "New Circuit",
                "icon": "$(new-file)",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.addFiles",
                "title": "Add Files",
                "icon": "$(add)",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.exportImage",
                "title": "Export Circuit As Image",
                "icon": "$(file-media)",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.showLuaTerminal",
                "title": "Show Lua Terminal",
                "icon": "$(terminal)",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.removeSource",
                "title": "Remove",
                "icon": "$(dash)",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.stopScript",
                "title": "Stop script",
                "icon": "$(debug-stop)",
                "category": "HDL Studio"
            },
            {
                "command": "hdl-studio.startScript",
                "title": "Start script",
                "icon": "$(debug-start)",
                "category": "HDL Studio"
            }
        ],
        "customEditors": [
            {
                "viewType": "hdl-studio.circuitView",
                "displayName": "HDL Studio",
                "selector": [
                    {
                        "filenamePattern": "*.digitaljs"
                    }
                ],
                "priority": "default"
            },
            {
                "viewType": "hdl-studio.circuitView_json",
                "displayName": "HDL Studio",
                "selector": [
                    {
                        "filenamePattern": "*.json"
                    }
                ],
                "priority": "option"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "hdl-studio.openView",
                    "when": "false"
                },
                {
                    "command": "hdl-studio.showPanel",
                    "when": "false"
                },
                {
                    "command": "hdl-studio.openViewJSON",
                    "when": "false"
                },
                {
                    "command": "hdl-studio.addToViewSource",
                    "when": "false"
                },
                {
                    "command": "hdl-studio.newViewSource",
                    "when": "false"
                },
                {
                    "command": "hdl-studio.revealCircuit",
                    "when": "false"
                },
                {
                    "command": "hdl-studio.pause",
                    "when": "false"
                },
                {
                    "command": "hdl-studio.start",
                    "when": "false"
                },
                {
                    "command": "hdl-studio.addFiles",
                    "when": "false"
                },
                {
                    "command": "hdl-studio.exportImage",
                    "when": "false"
                },
                {
                    "command": "hdl-studio.showLuaTerminal",
                    "when": "false"
                },
                {
                    "command": "hdl-studio.removeSource",
                    "when": "false"
                },
                {
                    "command": "hdl-studio.stopScript",
                    "when": "false"
                },
                {
                    "command": "hdl-studio.startScript",
                    "when": "false"
                }
            ],
            "view/title": [
                {
                    "command": "hdl-studio.newJSON",
                    "when": "view == hdl-studio-proj-files",
                    "group": "navigation@0"
                },
                {
                    "command": "hdl-studio.addFiles",
                    "when": "view == hdl-studio-proj-files",
                    "group": "navigation@1"
                },
                {
                    "command": "hdl-studio.exportImage",
                    "when": "view == hdl-studio-proj-files",
                    "group": "navigation@2"
                },
                {
                    "command": "hdl-studio.showLuaTerminal",
                    "when": "view == hdl-studio-proj-files",
                    "group": "navigation@3"
                }
            ],
            "editor/title": [
                {
                    "command": "hdl-studio.openView",
                    "when": "!hdl-studio.view_isfocus",
                    "group": "navigation"
                },
                {
                    "command": "hdl-studio.showPanel",
                    "when": "hdl-studio.view_isfocus",
                    "group": "navigation@0"
                },
                {
                    "command": "hdl-studio.pause",
                    "when": "hdl-studio.view_isfocus && hdl-studio.view_hascircuit && hdl-studio.view_running",
                    "group": "navigation@1"
                },
                {
                    "command": "hdl-studio.start",
                    "when": "hdl-studio.view_isfocus && hdl-studio.view_hascircuit && !hdl-studio.view_running",
                    "group": "navigation@1"
                }
            ],
            "explorer/context": [
                {
                    "command": "hdl-studio.openViewJSON",
                    "when": "resourceExtname == .json || resourceExtname == .digitaljs",
                    "group": "navigation@99999"
                },
                {
                    "command": "hdl-studio.addToViewSource",
                    "when": "hdl-studio.view_isactive && resourceExtname =~ /^\\.sv$|^\\.v$|^\\.vh$|^\\.lua$/",
                    "group": "navigation@99999"
                },
                {
                    "command": "hdl-studio.newViewSource",
                    "when": "resourceExtname =~ /^\\.sv$|^\\.v$|^\\.vh$|^\\.lua$/",
                    "group": "navigation@100000"
                }
            ],
            "view/item/context": [
                {
                    "command": "hdl-studio.removeSource",
                    "when": "view == hdl-studio-proj-files && viewItem != root-circuit",
                    "group": "inline"
                },
                {
                    "command": "hdl-studio.startScript",
                    "when": "view == hdl-studio-proj-files && viewItem in hdl-studio.script_not_running",
                    "group": "inline"
                },
                {
                    "command": "hdl-studio.stopScript",
                    "when": "view == hdl-studio-proj-files && viewItem in hdl-studio.script_running",
                    "group": "inline"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "hdl-studio-container",
                    "title": "HDL Studio",
                    "icon": "imgs/hdl-studio_mono.svg"
                }
            ]
        },
        "views": {
            "hdl-studio-container": [
                {
                    "id": "hdl-studio-proj-files",
                    "name": "Files",
                    "icon": "$(files)",
                    "contextualTitle": "HDL Studio Files"
                },
                {
                    "id": "hdl-studio-proj-synth",
                    "type": "webview",
                    "name": "Synthesis",
                    "icon": "$(gear)",
                    "contextualTitle": "HDL Studio Synthesis"
                },
                {
                    "id": "hdl-studio-proj-status",
                    "type": "webview",
                    "name": "Control",
                    "icon": "$(info)",
                    "contextualTitle": "HDL Studio Control"
                }
            ]
        },
        "configuration": {
            "title": "HDL Studio",
            "properties": {
                "hdl-studio.yosysPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the yosys executable. If empty, yosys from the PATH will be used."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "npm-run-all compile:*",
        "compile:views": "webpack --mode production",
        "watch": "npm-run-all watch:*",
        "watch:webpack": "webpack --watch --mode development",
        "watch-prod": "npm-run-all watch-prod:*",
        "watch-prod:webpack": "webpack --watch --mode production",
        "lint": "eslint .",
        "pretest": "npm run lint",
        "test": "node ./test/runTest.js",
        "open-in-browser": "vscode-test-web --extensionDevelopmentPath=. ."
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "26.x",
        "@types/vscode": "^1.125.0",
        "@vscode/test-electron": "^3.0.0",
        "@vscode/test-web": "^0.0.81",
        "css-loader": "^7.1.4",
        "eslint": "^10.5.0",
        "expose-loader": "^5.0.1",
        "glob": "^13.0.6",
        "jquery": "^4.0.0",
        "mocha": "^11.7.6",
        "npm-run-all": "^4.1.5",
        "process": "^0.11.10",
        "sass": "^1.101.0",
        "sass-loader": "^17.0.0",
        "style-loader": "^4.0.0",
        "webpack": "^5.107.2",
        "webpack-cli": "^7.0.3"
    },
    "dependencies": {
        "@vscode/codicons": "^0.0.45",
        "@vscode/webview-ui-toolkit": "^1.4.0",
        "3vl": "^1.0.1",
        "assert": "^2.1.0",
        "backbone": "^1.6.1",
        "base64-arraybuffer": "^1.0.2",
        "buffer": "^6.0.3",
        "crypto-browserify": "^3.12.1",
        "dequal": "^2.0.3",
        "digitaljs": "^0.14.2",
        "digitaljs_lua": "^0.0.9",
        "hammerjs": "^2.0.8",
        "luaparse": "^0.3.1",
        "path-browserify": "^1.0.1",
        "resize-observer-polyfill": "^1.5.1",
        "split-grid": "^1.0.11",
        "stream-browserify": "^3.0.0",
        "svg-pan-zoom": "^3.6.2",
        "util": "^0.12.5",
        "wavecanvas": "^1.1.1",
        "yosys2digitaljs": "^0.10.3"
    },
    "allowScripts": {
        "@parcel/watcher@2.5.6": true,
        "@vscode/vsce-sign@2.0.9": true,
        "keytar@7.9.0": true
    }
}
